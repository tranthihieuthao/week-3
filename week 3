import nltk
import re
import string  
# Download required NLTK resources (run once)
nltk.download('punkt')
nltk.download('punkt_tab')
nltk.download('stopwords')
nltk.download('wordnet')
nltk.download('omw-1.4')

from nltk.tokenize import word_tokenize
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer, WordNetLemmatizer
#Input text
text = """""Hello! I'm Thao Tran (Age: 20). My Email is tranthihieuthao@gmail.com. I'm a Tech-Enthusiast (ID: #98k_User). I love 100% coding & solving [complex] problems @home. My goal: 'Building 24/7 innovative apps!' I'm fluent in Python/C++ & enjoy learning {skills} daily. Can we connect? +84-767230992."""""
print("Original Text:", text)
print ("-"*50)
#tokenization
tokens = word_tokenize(text)
print("Tokens:", tokens)
